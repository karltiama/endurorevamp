# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Strava API (required for Strava integration)
NEXT_PUBLIC_STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
NEXT_PUBLIC_STRAVA_REDIRECT_URI=https://yourdomain.com/dashboard

# Strava Webhooks (optional, for real-time sync)
STRAVA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Background sync (optional, for cron)
BACKGROUND_SYNC_API_KEY=your_background_sync_api_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=admin@yourdomain.com
RESEND_DOMAIN=yourdomain.com

# Auth (password reset)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Weather (optional)
OPENWEATHER_API_KEY=your_openweather_api_key
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key
